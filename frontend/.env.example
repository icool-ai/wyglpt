# 复制为 .env.local 后在本目录执行 npm run dev
# 须从 frontend 目录启动，Next 才会读取本文件（根目录的 .env 不会自动带入）

NEXT_PUBLIC_API_BASE_URL=/api-backend
API_PROXY_TARGET=http://127.0.0.1:3001
# 开发代理等待后端响应的最长时间（毫秒）。LLM 较慢时可加大，避免 Next 代理先断开出现 socket hang up
# API_PROXY_TIMEOUT_MS=300000

# 若仍频繁出现代理断开，可让浏览器直连后端（同源 CORS 已在 backend main.ts 配置 localhost:3000）
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001
