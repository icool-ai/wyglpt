# 复制为 .env 后使用（与根目录 .env.example 二选一即可）

# --- 方式 A：本地 SQLite（无需 MySQL）---
DB_TYPE=sqlite
SQLITE_PATH=property_mgmt.sqlite
TYPEORM_SYNC=true

# --- 方式 B：连接 MySQL（可先 docker compose up -d mysql）---
# DB_TYPE=mysql
# DB_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=property
# MYSQL_PASSWORD=property123
# MYSQL_DATABASE=property_mgmt
# TYPEORM_SYNC=true

JWT_SECRET=change_me
JWT_EXPIRES_IN=7d
BACKEND_PORT=3001

# LLM / DeepSeek（LangChain DeepAgents 最小链路）
# 兼容旧变量：若未设置 DEEPSEEK_API_KEY，则回退读取 LLM_API_KEY。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPAGENTS_MODEL=deepseek-chat
